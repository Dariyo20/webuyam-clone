# MongoDB connection string (Atlas free tier or local)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/webuyam?retryWrites=true&w=majority

# JWT signing secret — use a long random string in production (min 32 chars)
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Server port (optional, defaults to 5000)
PORT=5000

# Environment (development | production)
NODE_ENV=development

# Allowed CORS origin for the frontend
CORS_ORIGIN=http://localhost:5173
