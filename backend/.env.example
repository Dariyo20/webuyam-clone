# MongoDB connection string (Atlas free tier or local)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/webuyam?retryWrites=true&w=majority

# JWT signing secret — use a long random string in production (min 32 chars)
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Server port (optional, defaults to 5000)
PORT=5000

# Environment (development | production)
NODE_ENV=development

# Allowed frontend origin(s) — comma-separate multiple values
# e.g. CLIENT_URL=https://webuyam.vercel.app,https://staging.webuyam.vercel.app
CLIENT_URL=http://localhost:5173
